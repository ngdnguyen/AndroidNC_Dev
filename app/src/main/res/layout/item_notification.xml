<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/llNotificationItem"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="55dp"
        android:layout_height="55dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivNotificationSender"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/empty_avatar" />

        <ImageView
            android:id="@+id/ivNotificationType"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/circle_white_bg"
            android:padding="4dp"
            android:src="@drawable/like"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNotificationMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User đã thích bài viết của bạn"
            android:textColor="@android:color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvNotificationTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 phút trước"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <View
        android:id="@+id/viewUnreadStatus"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_notification_badge"
        android:visibility="gone" />

</LinearLayout>